  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config jest.config.js",
    "test:story1": "jest --config jest.config.js src/tests/story1-language-selection.test.ts",
    "test:story2": "jest --config jest.config.js src/tests/story2-code-execution.test.ts",
    "test:story3": "jest --config jest.config.js src/tests/story3-opponent-progress.test.ts",
    "test:story4": "jest --config jest.config.js src/tests/story4-reconnection.test.ts",
    "test:story5": "jest --config jest.config.js src/tests/story5-auto-save.test.ts",
    "test:story6": "jest --config jest.config.js src/tests/story6-timer.test.ts",
    "test:story7": "jest --config jest.config.js src/tests/story7-view-solutions.test.ts",
    "test:story8": "jest --config jest.config.js src/tests/story8-problem-variety.test.ts",
    "test:story9": "jest --config jest.config.js src/tests/story9-difficulty-ratings.test.ts",
    "test:story10": "jest --config jest.config.js src/tests/story10-category-filter.test.ts",
    "test:story11": "jest --config jest.config.js src/tests/story11-match-history.test.ts",
