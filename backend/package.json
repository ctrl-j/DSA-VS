    "test:story13": "jest --config jest.config.js src/tests/story13-stats-visualization.test.ts",
    "test:all-stories": "jest --config jest.config.js src/tests/ --verbose --runInBand",
    "test:sprint3:userstory1": "jest --config jest.config.js src/tests/sprint3-userstory1.test.ts",
    "test:sprint3:userstory2": "jest --config jest.config.js src/tests/sprint3-userstory2.test.ts",
    "test:sprint3:userstory3": "jest --config jest.config.js src/tests/sprint3-userstory3.test.ts",
    "test:sprint3:userstory4": "jest --config jest.config.js src/tests/sprint3-userstory4.test.ts",
    "test:sprint3:userstory5": "jest --config jest.config.js src/tests/sprint3-userstory5.test.ts",
    "test:sprint3:userstory6": "jest --config jest.config.js src/tests/sprint3-userstory6.test.ts",
    "test:sprint3:userstory7": "jest --config jest.config.js src/tests/sprint3-userstory7.test.ts",
    "test:sprint3:userstory8": "jest --config jest.config.js src/tests/sprint3-userstory8.test.ts",
    "test:sprint3:userstory9": "jest --config jest.config.js src/tests/sprint3-userstory9.test.ts",
    "test:sprint3:userstory10": "jest --config jest.config.js src/tests/sprint3-userstory10.test.ts",
    "test:sprint3:userstory11": "jest --config jest.config.js src/tests/sprint3-userstory11.test.ts",
    "test:sprint3:userstory12": "jest --config jest.config.js src/tests/sprint3-userstory12.test.ts",
    "test-sprint3": "jest --config jest.config.js src/tests/sprint3-userstory*.test.ts --verbose --runInBand",
    "seed": "tsx prisma/seed.ts",
    "seed:leaderboard": "tsx prisma/seed-leaderboard.ts",
    "test:pipeline": "tsx scripts/test-pipeline.ts"
